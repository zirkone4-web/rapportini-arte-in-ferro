<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.CompanyCertificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Certificazioni aziendali · Arte In Ferro" Width="1320" Height="780"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="18">
        <Grid.ColumnDefinitions><ColumnDefinition Width="410"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="White" Padding="20" CornerRadius="12">
            <StackPanel>
                <TextBlock Text="Nuova certificazione" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Tipo *" FontWeight="SemiBold" Margin="0,14,0,0"/><ComboBox ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}"/>
                <TextBlock Text="Titolo *" FontWeight="SemiBold" Margin="0,10,0,0"/><TextBox Text="{Binding Title}"/>
                <TextBlock Text="Ente certificatore" FontWeight="SemiBold" Margin="0,10,0,0"/><TextBox Text="{Binding Issuer}"/>
                <TextBlock Text="Numero certificato" FontWeight="SemiBold" Margin="0,10,0,0"/><TextBox Text="{Binding CertificateNumber}"/>
                <TextBlock Text="Data rilascio" FontWeight="SemiBold" Margin="0,10,0,0"/><DatePicker SelectedDate="{Binding IssueDate}"/>
                <TextBlock Text="Data scadenza" FontWeight="SemiBold" Margin="0,10,0,0"/><DatePicker SelectedDate="{Binding ExpiryDate}"/>
                <TextBlock Text="Link documento" FontWeight="SemiBold" Margin="0,10,0,0"/><TextBox Text="{Binding DocumentUrl}"/>
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="0,14,0,10"/>
                <Button Content="SALVA CERTIFICAZIONE" Command="{Binding AddCommand}" Background="{StaticResource IronBlue}" Foreground="White" Height="44"/>
            </StackPanel>
        </Border>
        <DataGrid Grid.Column="2" ItemsSource="{Binding Certifications}" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="140"/>
                <DataGridTextColumn Header="Titolo" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Ente" Binding="{Binding Issuer}" Width="180"/>
                <DataGridTextColumn Header="Numero" Binding="{Binding CertificateNumber}" Width="160"/>
                <DataGridTextColumn Header="Rilascio" Binding="{Binding IssueDate, StringFormat=dd/MM/yyyy}" Width="110"/>
                <DataGridTextColumn Header="Scadenza" Binding="{Binding ExpiryDate, StringFormat=dd/MM/yyyy}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
