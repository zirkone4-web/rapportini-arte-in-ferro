<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.CommunicationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comunicazioni · Arte In Ferro" Width="900" Height="760"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="310" />
        </Grid.ColumnDefinitions>
        <Border Background="White" CornerRadius="12" Padding="22">
            <StackPanel>
                <TextBlock Text="Nuova comunicazione" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="Titolo *" FontWeight="SemiBold" Margin="0,18,0,0" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Messaggio *" FontWeight="SemiBold" Margin="0,12,0,0" />
                <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="220"
                         VerticalContentAlignment="Top" />
                <TextBlock Text="Priorità" FontWeight="SemiBold" Margin="0,12,0,0" />
                <ComboBox SelectedValue="{Binding Priority}" SelectedValuePath="Tag">
                    <ComboBoxItem Content="Normale" Tag="normale" />
                    <ComboBoxItem Content="Importante" Tag="importante" />
                    <ComboBoxItem Content="Urgente" Tag="urgente" />
                </ComboBox>
                <CheckBox Content="Richiedi conferma di lettura"
                          IsChecked="{Binding RequireConfirmation}" Margin="0,14,0,0" />
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Margin="0,18,0,10" />
                <Button Content="INVIA COMUNICAZIONE" Command="{Binding SendCommand}"
                        Background="{StaticResource IronBlue}" Foreground="White"
                        FontWeight="Bold" Height="48" />
            </StackPanel>
        </Border>
        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Destinatari" FontSize="20" FontWeight="Bold" />
                    <Button Content="Seleziona tutti" Command="{Binding SelectAllCommand}"
                            Margin="0,10,0,12" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Recipients}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"
                                          Margin="4,7" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
