<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.EmployeeAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dipendenti, amministratori e accessi · Arte In Ferro" Width="1260" Height="820"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="18">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="430"/></Grid.ColumnDefinitions>
        <DataGrid ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome e cognome" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="260"/>
                <DataGridTextColumn Header="Ruolo" Binding="{Binding Role}" Width="120"/>
                <DataGridTextColumn Header="Stato" Binding="{Binding StateLabel}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Column="2" Background="White" Padding="20" CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel>
                <TextBlock Text="Anagrafica e permessi" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Nome e cognome *" Margin="0,14,0,0"/><TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Email account (gestita da Supabase)"/><TextBox Text="{Binding SelectedEmployee.Email}" IsReadOnly="True"/>
                <TextBlock Text="Telefono"/><TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Mansione"/><TextBox Text="{Binding Job, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Reparto"/><TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"/>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="Assunzione"/><DatePicker SelectedDate="{Binding HireDate}"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Cessazione"/><DatePicker SelectedDate="{Binding EndDate}"/></StackPanel>
                </Grid>
                <TextBlock Text="Ruolo" Margin="0,10,0,0"/><ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" DisplayMemberPath="Label"/>
                <CheckBox Content="Account attivo" IsChecked="{Binding Active}" Margin="0,12"/>
                <TextBlock Text="Motivazione obbligatoria" FontWeight="SemiBold"/><TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"/>
                <Button Content="SALVA ANAGRAFICA E PERMESSI" Command="{Binding SaveEmployeeCommand}" Background="{StaticResource IronBlue}" Foreground="White"/>
                <Separator Margin="0,18"/>
                <TextBlock Text="Nuova password temporanea" FontWeight="SemiBold"/><TextBox Text="{Binding TemporaryPassword, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="IMPOSTA PASSWORD" Command="{Binding ResetPasswordCommand}" Background="#FEF3C7"/>
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="0,16,0,0"/>
            </StackPanel></ScrollViewer>
        </Border>
    </Grid>
</Window>
