<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.ReportEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifica rapportino" Width="760" Height="820"
        MinWidth="660" MinHeight="680" WindowStartupLocation="CenterOwner"
        Background="#F1F5F9" ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Margin="4,0,4,14">
            <TextBlock Text="{Binding Title}" FontSize="21" FontWeight="Bold"
                       Foreground="{StaticResource IronBlue}" />
            <TextBlock Text="Modifica i dati, approva o respingi il rapportino."
                       Foreground="#64748B" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" Padding="24" CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Luogo *" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Place, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Riferimento appuntamento" FontWeight="SemiBold" />
                        <TextBox Text="{Binding AppointmentReference}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="Tipo intervento" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Interventions}"
                                  SelectedItem="{Binding SelectedIntervention}" Margin="0,4,0,10" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Stato" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Statuses}"
                                  SelectedItem="{Binding SelectedStatus}" Margin="0,4,0,10" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Inizio (gg/mm/aaaa hh:mm) *" FontWeight="SemiBold" />
                        <TextBox Text="{Binding StartText}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Text="Fine (gg/mm/aaaa hh:mm) *" FontWeight="SemiBold" />
                        <TextBox Text="{Binding EndText}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="Descrizione attività *" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="120"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="Motivazione modifica / nota amministratore *" FontWeight="SemiBold" />
                        <TextBox Text="{Binding AdminNote}" AcceptsReturn="True"
                                 TextWrapping="Wrap" Height="86" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="ANNULLA" IsCancel="True" />
            <Button Content="SALVA MODIFICHE" Command="{Binding SaveCommand}"
                    Background="{StaticResource IronBlue}" Foreground="White"
                    FontWeight="Bold" MinWidth="170" />
        </StackPanel>
    </Grid>
</Window>
