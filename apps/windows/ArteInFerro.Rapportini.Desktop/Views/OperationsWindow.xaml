<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.OperationsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Carburante e anomalie · Arte In Ferro" Width="1350" Height="780" WindowStartupLocation="CenterOwner" Background="#F1F5F9">
 <TabControl Margin="18">
  <TabItem Header="RIFORNIMENTI"><DataGrid Margin="10" ItemsSource="{Binding FuelEntries}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns>
   <DataGridTextColumn Header="Data" Binding="{Binding DateTime.LocalDateTime, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/><DataGridTextColumn Header="Dipendente" Binding="{Binding EmployeeName}" Width="190"/><DataGridTextColumn Header="Mezzo" Binding="{Binding VehicleName}" Width="220"/><DataGridTextColumn Header="Km" Binding="{Binding Km}" Width="100"/><DataGridTextColumn Header="Litri" Binding="{Binding Liters, StringFormat=N2}" Width="100"/><DataGridTextColumn Header="Importo" Binding="{Binding Amount, StringFormat=C}" Width="110"/><DataGridTextColumn Header="Distributore" Binding="{Binding Station}" Width="*"/>
  </DataGrid.Columns></DataGrid></TabItem>
  <TabItem Header="ANOMALIE"><Grid Margin="10"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
   <DataGrid ItemsSource="{Binding Anomalies}" SelectedItem="{Binding SelectedAnomaly}" AutoGenerateColumns="False" IsReadOnly="True"><DataGrid.Columns>
    <DataGridTextColumn Header="Data" Binding="{Binding CreatedAt.LocalDateTime, StringFormat=dd/MM/yyyy HH:mm}" Width="145"/><DataGridTextColumn Header="Stato" Binding="{Binding Status}" Width="110"/><DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="110"/><DataGridTextColumn Header="Dipendente" Binding="{Binding EmployeeName}" Width="180"/><DataGridTextColumn Header="Titolo" Binding="{Binding Title}" Width="220"/><DataGridTextColumn Header="Descrizione" Binding="{Binding Description}" Width="*"/><DataGridTextColumn Header="Mezzo" Binding="{Binding VehicleName}" Width="180"/>
   </DataGrid.Columns></DataGrid>
   <Border Grid.Row="1" Background="White" Padding="14" Margin="0,10,0,0" CornerRadius="10"><DockPanel><Button DockPanel.Dock="Right" Content="SEGNA RISOLTA" Command="{Binding ResolveCommand}" Background="{StaticResource IronBlue}" Foreground="White"/><TextBox Text="{Binding ResolutionNote}" MinWidth="400" Margin="0,0,12,0" ToolTip="Nota di risoluzione"/><TextBlock Text="{Binding Message}" Margin="12,4"/></DockPanel></Border>
  </Grid></TabItem>
 </TabControl>
</Window>
