<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.PlanningCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuovo lavoro"
        Width="880" Height="780" MinWidth="760" MinHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBackground}"
        Loaded="WindowLoaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeadingText" Text="Nuovo lavoro"
                       Style="{StaticResource SectionTitle}" />
            <TextBlock x:Name="SubheadingText"
                       Text="Assegna il lavoro a una persona o a una squadra."
                       Foreground="#647483" Margin="0,4,0,14" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="Responsabile *" FontWeight="SemiBold" />
                        <ComboBox x:Name="ResponsibleCombo" IsEditable="True"
                                  IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                  MinHeight="38" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Text="Cliente *" FontWeight="SemiBold" />
                        <ComboBox x:Name="ClientCombo" IsEditable="True"
                                  IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                  MinHeight="38" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                        <TextBlock Text="Cantiere" FontWeight="SemiBold" />
                        <ComboBox x:Name="WorksiteCombo" IsEditable="True"
                                  IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                  MinHeight="38" SelectionChanged="WorksiteChanged" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                        <TextBlock Text="Mezzo assegnato" FontWeight="SemiBold" />
                        <ComboBox x:Name="VehicleCombo" IsEditable="True"
                                  IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                  MinHeight="38" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,12,0,0">
                        <TextBlock Text="Data *" FontWeight="SemiBold" />
                        <DatePicker x:Name="WorkDatePicker" MinHeight="38" />
                    </StackPanel>
                    <Grid Grid.Row="2" Grid.Column="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Inizio *" FontWeight="SemiBold" />
                            <TextBox x:Name="StartTimeText" Text="07:30" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fine *" FontWeight="SemiBold" />
                            <TextBox x:Name="EndTimeText" Text="18:00" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,12,0,0">
                        <TextBlock Text="Tipo intervento *" FontWeight="SemiBold" />
                        <ComboBox x:Name="InterventionCombo" MinHeight="38" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,12,0,0">
                        <TextBlock Text="Luogo / indirizzo *" FontWeight="SemiBold" />
                        <TextBox x:Name="PlaceText" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Margin="0,12,0,0">
                        <TextBlock Text="Squadra" FontWeight="SemiBold" />
                        <TextBlock Text="Seleziona gli altri dipendenti coinvolti. Il responsabile non va riselezionato."
                                   Foreground="#647483" FontSize="12" Margin="0,2,0,6" />
                        <ListBox x:Name="CollaboratorsList" SelectionMode="Multiple"
                                 DisplayMemberPath="Label" MinHeight="105" MaxHeight="160" />
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.ColumnSpan="3" Margin="0,12,0,0">
                        <TextBlock Text="Attività da eseguire *" FontWeight="SemiBold" />
                        <TextBox x:Name="DescriptionText" MinHeight="84"
                                 AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.ColumnSpan="3" Margin="0,12,0,0">
                        <TextBlock Text="Note dell'ufficio" FontWeight="SemiBold" />
                        <TextBox x:Name="PlanningNotesText" MinHeight="68"
                                 AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="#647483" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Annulla" Click="CancelClick" />
                <Button x:Name="SaveButton" Content="Salva e assegna"
                        Click="SaveClick" Background="{StaticResource IronBlue}"
                        Foreground="White" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>