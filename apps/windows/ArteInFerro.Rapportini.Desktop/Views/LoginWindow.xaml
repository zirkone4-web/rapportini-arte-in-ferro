<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arte in Ferro · Accesso"
        Width="520" Height="620"
        MinWidth="440" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid>
        <Border Width="400" Padding="34" Background="White" CornerRadius="18"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <Border Height="112" Background="White" CornerRadius="12">
                    <Image Source="/Assets/logo_arte_in_ferro.png" Stretch="Uniform" />
                </Border>
                <TextBlock Text="Gestione rapportini · Amministrazione"
                           Foreground="#64748B" Margin="0,14,0,28" TextAlignment="Center" />

                <TextBlock Text="Email" FontWeight="SemiBold" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Email" />
                <TextBlock Text="Password" FontWeight="SemiBold" />
                <PasswordBox x:Name="PasswordInput" PasswordChanged="PasswordChanged"
                             MinHeight="38" Padding="8,5" Margin="0,4,0,18"
                             AutomationProperties.Name="Password" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#B91C1C"
                           TextWrapping="Wrap" Margin="0,0,0,12" />
                <Button Content="ACCEDI" Command="{Binding LoginCommand}"
                        IsDefault="True" Background="{StaticResource IronBlue}"
                        Foreground="White" FontWeight="Bold" Height="48" />
                <ProgressBar IsIndeterminate="True" Height="4" Margin="4,10"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Text="Accesso consentito solo agli amministratori attivi."
                           Foreground="#64748B" TextAlignment="Center" FontSize="12"
                           Margin="0,14,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
