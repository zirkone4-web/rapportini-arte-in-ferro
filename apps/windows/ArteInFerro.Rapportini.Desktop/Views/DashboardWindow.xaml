<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arte In Ferro Lascari · Management"
        Width="1500" Height="900" MinWidth="1100" MinHeight="680"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource IronBlue}" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="46" Height="46" Background="White" CornerRadius="10">
                        <TextBlock Text="AF" Foreground="{StaticResource IronBlue}"
                                   FontWeight="Bold" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ARTE IN FERRO" Foreground="White"
                                   FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="Piattaforma Management" Foreground="#D8E7F5" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Amministratore" Foreground="#D8E7F5"
                               HorizontalAlignment="Right" FontSize="11" />
                    <TextBlock Text="{Binding AdminName}" Foreground="White"
                               FontWeight="SemiBold" FontSize="15" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="18,14" Margin="16,16,16,8"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="145" />
                    <ColumnDefinition Width="145" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="175" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Dal" FontWeight="SemiBold" />
                    <DatePicker SelectedDate="{Binding DateFrom}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Al" FontWeight="SemiBold" />
                    <DatePicker SelectedDate="{Binding DateTo}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Dipendente" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding Employees}"
                              SelectedItem="{Binding SelectedEmployee}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Cliente" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding Clients}"
                              SelectedItem="{Binding SelectedClient}" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Stato" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding Statuses}"
                              SelectedItem="{Binding SelectedStatus}" />
                </StackPanel>
                <Button Grid.Column="5" Content="APPLICA FILTRI"
                        Command="{Binding ApplyFiltersCommand}"
                        VerticalAlignment="Bottom" Background="{StaticResource IronBlue}"
                        Foreground="White" FontWeight="Bold" />
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="16,0,16,8">
            <Button Content="Azienda e contatti" Click="CompanySettingsClick" Background="#E2E8F0" FontWeight="SemiBold" />
            <Button Content="Nuovo dipendente" Click="NewEmployeeClick"
                    Background="#DBEAFE" FontWeight="SemiBold" />
            <Button Content="Dipendenti e accessi" Click="EmployeeAccessClick"
                    Background="#DBEAFE" FontWeight="SemiBold" />
            <Button Content="Presenze e straordinari" Click="AttendanceClick"
                    Background="#DCFCE7" FontWeight="SemiBold" />
            <Button Content="Corsi, patentini e visite" Click="EmployeeDocumentsClick"
                    Background="#EDE9FE" FontWeight="SemiBold" />
            <Button Content="Comunicazioni" Click="CommunicationsClick"
                    Background="#FFEDD5" FontWeight="SemiBold" />
            <Button Content="Mezzi e assicurazioni" Click="FleetClick"
                    Background="#E0F2FE" FontWeight="SemiBold" />
            <Button Content="Carburante e anomalie" Click="OperationsClick" Background="#FEE2E2" FontWeight="SemiBold" />
            <Button Content="Scadenziario" Click="DeadlinesClick"
                    Background="#FEF3C7" FontWeight="SemiBold" />
            <Button Content="Certificazioni azienda" Click="CompanyCertificationsClick"
                    Background="#FCE7F3" FontWeight="SemiBold" />
            <Button Content="Aggiorna" Command="{Binding LoadCommand}" />
            <Button Content="Apri / modifica / approva" Command="{Binding EditCommand}"
                    Background="#DCFCE7" />
            <Separator Width="18" Opacity="0" />
            <Button Content="Esporta Excel" Command="{Binding ExportExcelCommand}" />
            <Button Content="Genera PDF" Command="{Binding ExportPdfCommand}" />
            <ProgressBar IsIndeterminate="True" Width="130" Height="5" Margin="16,0"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
        </WrapPanel>

        <Border Grid.Row="3" Background="White" Margin="16,0" CornerRadius="12" Padding="4">
            <DataGrid ItemsSource="{Binding Reports}"
                      SelectedItem="{Binding SelectedReport}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      CanUserSortColumns="True" CanUserReorderColumns="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      RowHeight="40" MouseDoubleClick="ReportDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding StartAt.LocalDateTime, StringFormat=dd/MM/yyyy HH:mm}" Width="145" />
                    <DataGridTextColumn Header="Dipendente" Binding="{Binding EmployeeName}" Width="180" />
                    <DataGridTextColumn Header="Cliente" Binding="{Binding ClientName}" Width="210" />
                    <DataGridTextColumn Header="Luogo" Binding="{Binding Place}" Width="200" />
                    <DataGridTextColumn Header="Targa" Binding="{Binding VehiclePlate}" Width="100" />
                    <DataGridTextColumn Header="Km" Binding="{Binding VehicleKm, StringFormat=N0}" Width="85" />
                    <DataGridTextColumn Header="Intervento" Binding="{Binding InterventionLabel}" Width="190" />
                    <DataGridTextColumn Header="Ore" Binding="{Binding TotalHours, StringFormat=N2}" Width="70" />
                    <DataGridTextColumn Header="Stato" Binding="{Binding Status}" Width="100" />
                    <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}" Width="*" />
                    <DataGridTextColumn Header="Nota ufficio" Binding="{Binding AdminNote}" Width="200" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4" Background="#E2E8F0" Padding="18,8">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
