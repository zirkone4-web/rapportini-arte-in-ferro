<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.MainShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arte In Ferro Lascari · Gestionale"
        Width="1500" Height="900" MinWidth="1180" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E8F0F7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="10,2" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="42" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#234D70" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactAction" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="3" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="238" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- MENU LATERALE -->
        <Border Grid.Column="0" Background="{StaticResource IronBlueDark}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="92" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="62" />
                </Grid.RowDefinitions>

                <Border Margin="14,14,14,10" Background="White" CornerRadius="10" Padding="10">
                    <Image Source="/Assets/logo_arte_in_ferro.png" Stretch="Uniform" />
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="GESTIONE" Foreground="#8FA9BE" FontSize="11"
                                   FontWeight="Bold" Margin="22,12,0,6" />
                        <Button Style="{StaticResource SidebarButton}" Content="Dashboard"
                                Click="DashboardClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Pianificazione lavori"
                                Click="PlanningClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Rapportini"
                                Click="ReportsClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Presenze"
                                Click="AttendanceClick" />

                        <TextBlock Text="ANAGRAFICHE" Foreground="#8FA9BE" FontSize="11"
                                   FontWeight="Bold" Margin="22,18,0,6" />
                        <Button Style="{StaticResource SidebarButton}" Content="Clienti e cantieri"
                                Click="MasterDataClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Dipendenti e accessi"
                                Click="EmployeeAccessClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Corsi, visite e patentini"
                                Click="EmployeeDocumentsClick" />

                        <TextBlock Text="OPERATIVITÀ" Foreground="#8FA9BE" FontSize="11"
                                   FontWeight="Bold" Margin="22,18,0,6" />
                        <Button Style="{StaticResource SidebarButton}" Content="Comunicazioni"
                                Click="CommunicationsClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Mezzi e assicurazioni"
                                Click="FleetClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Carburante e anomalie"
                                Click="OperationsClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Scadenziario"
                                Click="DeadlinesClick" />

                        <TextBlock Text="AZIENDA" Foreground="#8FA9BE" FontSize="11"
                                   FontWeight="Bold" Margin="22,18,0,6" />
                        <Button Style="{StaticResource SidebarButton}" Content="Dati azienda e contatti"
                                Click="CompanySettingsClick" />
                        <Button Style="{StaticResource SidebarButton}" Content="Certificazioni azienda"
                                Click="CompanyCertificationsClick" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="18,7">
                    <TextBlock Text="Arte In Ferro Lascari" Foreground="#B8C9D8"
                               FontSize="12" />
                    <TextBlock Text="Nuovo gestionale · fase 1" Foreground="#6F8DA5"
                               FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- AREA PRINCIPALE -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderLight}"
                    BorderThickness="0,0,0,1" Padding="22,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitle" Text="Dashboard"
                                   FontSize="24" FontWeight="SemiBold" Foreground="#17212B" />
                        <TextBlock Text="Centro operativo Arte In Ferro Lascari"
                                   Foreground="#647483" FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="100" Height="5" Margin="8"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="Aggiorna" Command="{Binding LoadCommand}"
                                Style="{StaticResource CompactAction}" />
                        <Border Background="#E8F0F7" CornerRadius="18" Padding="14,7" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Amministratore" FontSize="10" Foreground="#657989" />
                                <TextBlock Text="{Binding AdminName}" FontWeight="SemiBold"
                                           Foreground="{StaticResource IronBlue}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18">

                <!-- DASHBOARD -->
                <ScrollViewer x:Name="HomePanel" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Situazione generale" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Le informazioni principali sono raccolte in un'unica schermata."
                                   Foreground="#647483" Margin="0,3,0,14" />

                        <UniformGrid Columns="3" Margin="0,0,0,16">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Rapportini caricati" Foreground="#687987" />
                                    <TextBlock Text="{Binding Reports.Count}" FontSize="32"
                                               FontWeight="Bold" Foreground="{StaticResource IronBlue}" />
                                    <Button Content="Apri rapportini" Click="ReportsClick"
                                            HorizontalAlignment="Left" Style="{StaticResource CompactAction}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Presenze disponibili" Foreground="#687987" />
                                    <TextBlock Text="{Binding Attendance.Count}" FontSize="32"
                                               FontWeight="Bold" Foreground="#1F7A4D" />
                                    <Button Content="Gestisci presenze" Click="AttendanceClick"
                                            HorizontalAlignment="Left" Style="{StaticResource CompactAction}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Scadenze registrate" Foreground="#687987" />
                                    <TextBlock Text="{Binding Deadlines.Count}" FontSize="32"
                                               FontWeight="Bold" Foreground="#B45C20" />
                                    <Button Content="Apri scadenziario" Click="DeadlinesClick"
                                            HorizontalAlignment="Left" Style="{StaticResource CompactAction}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Ultimi rapportini" FontSize="17"
                                               FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding Reports}"
                                              SelectedItem="{Binding SelectedReport}"
                                              AutoGenerateColumns="False" IsReadOnly="True"
                                              RowHeight="36" MaxHeight="390"
                                              MouseDoubleClick="ReportDoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Data"
                                                Binding="{Binding StartAt.LocalDateTime, StringFormat=dd/MM HH:mm}"
                                                Width="115" />
                                            <DataGridTextColumn Header="Dipendente"
                                                Binding="{Binding EmployeeName}" Width="160" />
                                            <DataGridTextColumn Header="Cliente"
                                                Binding="{Binding ClientName}" Width="190" />
                                            <DataGridTextColumn Header="Stato"
                                                Binding="{Binding Status}" Width="95" />
                                            <DataGridTextColumn Header="Descrizione"
                                                Binding="{Binding Description}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Azioni rapide" FontSize="17"
                                               FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <Button Content="Pianifica lavoro" Click="NewPlanningClick"
                                            HorizontalContentAlignment="Left" />
                                    <Button Content="Nuovo rapportino" Click="NewReportClick"
                                            HorizontalContentAlignment="Left" />
                                    <Button Content="Nuovo dipendente" Click="NewEmployeeClick"
                                            HorizontalContentAlignment="Left" />
                                    <Button Content="Clienti e cantieri" Click="MasterDataClick"
                                            HorizontalContentAlignment="Left" />
                                    <Button Content="Invia comunicazione" Click="CommunicationsClick"
                                            HorizontalContentAlignment="Left" />
                                    <Button Content="Gestisci mezzi" Click="FleetClick"
                                            HorizontalContentAlignment="Left" />
                                    <Button Content="Dati azienda" Click="CompanySettingsClick"
                                            HorizontalContentAlignment="Left" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- RAPPORTINI -->
                <Grid x:Name="ReportsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="135" />
                                <ColumnDefinition Width="135" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="155" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Dal" FontWeight="SemiBold" />
                                <DatePicker SelectedDate="{Binding DateFrom}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Al" FontWeight="SemiBold" />
                                <DatePicker SelectedDate="{Binding DateTo}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Dipendente" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding Employees}"
                                          SelectedItem="{Binding SelectedEmployee}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                <TextBlock Text="Cliente" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding Clients}"
                                          SelectedItem="{Binding SelectedClient}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                <TextBlock Text="Stato" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding Statuses}"
                                          SelectedItem="{Binding SelectedStatus}" />
                            </StackPanel>
                            <Button Grid.Column="5" Content="Applica"
                                    Command="{Binding ApplyFiltersCommand}"
                                    VerticalAlignment="Bottom"
                                    Background="{StaticResource IronBlue}" Foreground="White" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Nuovo rapportino" Click="NewReportClick"
                                Background="#CFE7FF" />
                        <Button Content="Apri / modifica / approva" Command="{Binding EditCommand}"
                                Background="#DDF3E5" />
                        <Button Content="Esporta Excel" Command="{Binding ExportExcelCommand}" />
                        <Button Content="Genera PDF" Command="{Binding ExportPdfCommand}" />
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="4">
                        <DataGrid ItemsSource="{Binding Reports}"
                                  SelectedItem="{Binding SelectedReport}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  CanUserSortColumns="True" CanUserReorderColumns="True"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  RowHeight="38" MouseDoubleClick="ReportDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Data"
                                    Binding="{Binding StartAt.LocalDateTime, StringFormat=dd/MM/yyyy HH:mm}"
                                    Width="145" />
                                <DataGridTextColumn Header="Dipendente"
                                    Binding="{Binding EmployeeName}" Width="175" />
                                <DataGridTextColumn Header="Cliente"
                                    Binding="{Binding ClientName}" Width="200" />
                                <DataGridTextColumn Header="Luogo"
                                    Binding="{Binding Place}" Width="180" />
                                <DataGridTextColumn Header="Intervento"
                                    Binding="{Binding InterventionLabel}" Width="175" />
                                <DataGridTextColumn Header="Ore"
                                    Binding="{Binding TotalHours, StringFormat=N2}" Width="70" />
                                <DataGridTextColumn Header="Stato"
                                    Binding="{Binding Status}" Width="95" />
                                <DataGridTextColumn Header="Descrizione"
                                    Binding="{Binding Description}" Width="*" />
                                <DataGridTextColumn Header="Nota ufficio"
                                    Binding="{Binding AdminNote}" Width="190" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- PIANIFICAZIONE LAVORI -->
                <Grid x:Name="PlanningPanel" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorder}" HorizontalAlignment="Stretch"
                            VerticalAlignment="Top" Padding="26">
                        <StackPanel>
                            <TextBlock Text="Pianificazione lavori" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Crea una giornata singola o di squadra e inviala alle app dei dipendenti."
                                       Foreground="#647483" Margin="0,5,0,18" />
                            <Border Background="#E8F0F7" CornerRadius="10" Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Flusso operativo" FontWeight="Bold"
                                               Foreground="{StaticResource IronBlue}" />
                                    <TextBlock TextWrapping="Wrap" Margin="0,6,0,0"
                                               Text="Scegli responsabile, collaboratori, cliente, cantiere, mezzo, orari e attività. Il lavoro comparirà nell'app come assegnato dall'ufficio." />
                                    <Button Content="NUOVA PIANIFICAZIONE" Click="NewPlanningClick"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource IronBlue}" Foreground="White" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="#E4EAF0" Padding="16,7">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#455867" />
            </Border>
        </Grid>
    </Grid>
</Window>
