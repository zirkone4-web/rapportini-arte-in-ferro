<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.AttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Presenze lavoratori · Arte In Ferro" Width="1540" Height="900"
        MinWidth="1240" MinHeight="720"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Presenze lavoratori" FontSize="25" FontWeight="Bold"/>
                <TextBlock Text="Tutti i dipendenti con accesso sono sempre visibili, anche senza timbrature."
                           Foreground="#647483" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Content="AGGIORNA" Command="{Binding LoadCommand}" DockPanel.Dock="Right"
                    VerticalAlignment="Center"/>
        </DockPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="GIORNO" Command="{Binding SetPeriodCommand}" CommandParameter="day"/>
                    <Button Content="SETTIMANA" Command="{Binding SetPeriodCommand}" CommandParameter="week"/>
                    <Button Content="MESE" Command="{Binding SetPeriodCommand}" CommandParameter="month"/>
                    <Button Content="ANNO" Command="{Binding SetPeriodCommand}" CommandParameter="year"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="‹" Command="{Binding PreviousPeriodCommand}" FontSize="20" Padding="12,2"/>
                    <TextBlock Text="{Binding PeriodLabel}" MinWidth="260" TextAlignment="Center"
                               FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    <Button Content="›" Command="{Binding NextPeriodCommand}" FontSize="20" Padding="12,2"/>
                </StackPanel>
                <Button Grid.Column="4" Content="OGGI" Command="{Binding TodayCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="390"/>
            </Grid.ColumnDefinitions>
            <TabControl>
                <TabItem Header="GRIGLIA PRESENZE">
                    <DataGrid ItemsSource="{Binding GridRows}" SelectedItem="{Binding SelectedGridRow}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True"
                              Background="White" RowHeight="40" FrozenColumnCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dipendente" Binding="{Binding EmployeeName}" Width="210"/>
                            <DataGridTextColumn Header="Accesso app" Binding="{Binding AccessLabel}" Width="105"/>
                            <DataGridTextColumn Header="Stato" Binding="{Binding StatusLabel}" Width="135"/>
                            <DataGridTextColumn Header="Prima entrata" Binding="{Binding FirstEntry.LocalDateTime, StringFormat=dd/MM HH:mm}" Width="110"/>
                            <DataGridTextColumn Header="Ultima uscita" Binding="{Binding LastExit.LocalDateTime, StringFormat=dd/MM HH:mm}" Width="110"/>
                            <DataGridTextColumn Header="Giorni lavorati" Binding="{Binding WorkedDays}" Width="105"/>
                            <DataGridTextColumn Header="Giorni mancanti" Binding="{Binding MissingDays}" Width="110"/>
                            <DataGridTextColumn Header="Ore" Binding="{Binding TotalHours, StringFormat=N2}" Width="75"/>
                            <DataGridTextColumn Header="Compensazione" Binding="{Binding CompensationHours, StringFormat=N2}" Width="105"/>
                            <DataGridTextColumn Header="Trasferte da verificare" Binding="{Binding PendingTransfers}" Width="145"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="TIMBRATURE E MAPPA">
                    <DataGrid ItemsSource="{Binding Events}" SelectedItem="{Binding SelectedEvent}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True"
                              Background="White" RowHeight="38">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data e ora" Binding="{Binding RegisteredAt.LocalDateTime, StringFormat=dd/MM/yyyy HH:mm}" Width="145"/>
                            <DataGridTextColumn Header="Dipendente" Binding="{Binding EmployeeName}" Width="190"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TypeLabel}" Width="80"/>
                            <DataGridTextColumn Header="Modalità" Binding="{Binding ModeLabel}" Width="90"/>
                            <DataGridTextColumn Header="Sede / cantiere" Binding="{Binding LocationLabel}" Width="210"/>
                            <DataGridTextColumn Header="Verifica" Binding="{Binding VerificationLabel}" Width="110"/>
                            <DataGridTextColumn Header="Distanza m" Binding="{Binding DistanceMeters, StringFormat=N0}" Width="90"/>
                            <DataGridCheckBoxColumn Header="Forzata" Binding="{Binding ForcedByAdmin}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>

            <Border Grid.Column="2" Background="White" Padding="18" CornerRadius="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Correzioni amministrative" FontSize="21" FontWeight="Bold"/>
                        <TextBlock Text="Le autorizzazioni giornaliere sono disponibili nella vista Giorno."
                                   Foreground="#647483" TextWrapping="Wrap" Margin="0,4,0,8"/>
                        <TextBlock Text="Timbratura selezionata" FontWeight="SemiBold" Margin="0,10,0,2"/>
                        <TextBlock Text="{Binding SelectedEvent.EmployeeName}" FontSize="16"/>
                        <TextBlock Text="Data e ora (gg/mm/aaaa hh:mm)" Margin="0,10,0,0"/>
                        <TextBox Text="{Binding EventDateTimeText, UpdateSourceTrigger=PropertyChanged}"/>
                        <WrapPanel>
                            <Button Content="SALVA ORARIO" Command="{Binding SaveEventTimeCommand}" Background="#DBEAFE"/>
                            <Button Content="APRI MAPPA" Command="{Binding OpenMapCommand}"/>
                        </WrapPanel>
                        <WrapPanel>
                            <Button Content="AUTORIZZA TRASFERTA" Command="{Binding ApproveTransferCommand}" Background="#DCFCE7"/>
                            <Button Content="RIFIUTA" Command="{Binding RejectTransferCommand}" Background="#FEE2E2"/>
                        </WrapPanel>
                        <Separator Margin="0,16"/>
                        <TextBlock Text="Autorizzazione ore giornata" FontWeight="Bold"/>
                        <TextBlock Text="Dipendente selezionato" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding SelectedGridRow.EmployeeName}" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding HoursStatuses}" SelectedItem="{Binding SelectedHoursStatus}"
                                  DisplayMemberPath="Label" Margin="0,6,0,8"/>
                        <TextBlock Text="Ore autorizzate"/>
                        <TextBox Text="{Binding AuthorizedHoursText, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="SALVA AUTORIZZAZIONE ORE" Command="{Binding AuthorizeHoursCommand}" Background="#DCFCE7"/>
                        <Separator Margin="0,16"/>
                        <TextBlock Text="Inserimento forzato" FontWeight="Bold"/>
                        <TextBlock Text="Dipendente" Margin="0,8,0,0"/>
                        <ComboBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" DisplayMemberPath="Label"/>
                        <TextBlock Text="Data e ora" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding ForceDateTimeText, UpdateSourceTrigger=PropertyChanged}"/>
                        <WrapPanel>
                            <Button Content="FORZA ENTRATA" Command="{Binding ForceEntryCommand}"/>
                            <Button Content="FORZA USCITA" Command="{Binding ForceExitCommand}" Background="#FEF3C7"/>
                        </WrapPanel>
                        <TextBlock Text="Motivazione obbligatoria" FontWeight="SemiBold" Margin="0,14,0,0"/>
                        <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                                 MinHeight="70" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#E2E8F0" Padding="12" Margin="0,12,0,0">
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
