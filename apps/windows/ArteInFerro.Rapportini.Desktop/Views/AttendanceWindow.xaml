<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.AttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Presenze e straordinari · Arte In Ferro" Width="1100" Height="720"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Presenze e straordinari" FontSize="24" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,24,0" />
            <Button Content="Aggiorna" Command="{Binding LoadCommand}" />
            <Button Content="Esporta Excel" Command="{Binding ExportAttendanceCommand}"
                    Background="#DCFCE7" FontWeight="SemiBold" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Attendance}" AutoGenerateColumns="False"
                  IsReadOnly="True" CanUserSortColumns="True" RowHeight="38"
                  Background="White" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data" Binding="{Binding Day, StringFormat=dd/MM/yyyy}" Width="130" />
                <DataGridTextColumn Header="Dipendente" Binding="{Binding EmployeeName}" Width="*" />
                <DataGridTextColumn Header="Entrata" Binding="{Binding FirstEntry.LocalDateTime, StringFormat=HH:mm}" Width="130" />
                <DataGridTextColumn Header="Uscita" Binding="{Binding LastExit.LocalDateTime, StringFormat=HH:mm}" Width="130" />
                <DataGridTextColumn Header="Ore lavorate" Binding="{Binding TotalHours, StringFormat=N2}" Width="140" />
                <DataGridTextColumn Header="Straordinario" Binding="{Binding OvertimeHours, StringFormat=N2}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
