<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.EmployeeAccessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dipendenti e accessi · Arte In Ferro" Width="1120" Height="680"
        WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <Grid Margin="18">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="350"/></Grid.ColumnDefinitions>
        <DataGrid ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome e cognome" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="260"/>
                <DataGridTextColumn Header="Stato" Binding="{Binding StateLabel}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Column="2" Background="White" Padding="20" CornerRadius="12">
            <StackPanel>
                <TextBlock Text="Gestione accesso" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Dipendente selezionato" FontWeight="SemiBold" Margin="0,18,0,2"/>
                <TextBlock Text="{Binding SelectedEmployee.FullName}" FontSize="17"/>
                <Button Content="ATTIVA / DISATTIVA ACCESSO" Command="{Binding ToggleActiveCommand}" Margin="0,18,0,0" Background="#FEF3C7" Foreground="#713F12"/>
                <Separator Margin="0,24"/>
                <TextBlock Text="Nuova password temporanea" FontWeight="SemiBold"/>
                <TextBox Text="{Binding TemporaryPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>
                <Button Content="IMPOSTA PASSWORD" Command="{Binding ResetPasswordCommand}" Background="{StaticResource IronBlue}" Foreground="White"/>
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
