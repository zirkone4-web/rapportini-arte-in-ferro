<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.EmployeeCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuovo dipendente · Arte In Ferro" Width="620" Height="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F1F5F9">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Nuovo dipendente e accesso" FontSize="25" FontWeight="Bold" />
            <TextBlock Text="L’account sarà creato direttamente su Supabase con ruolo Operatore."
                       Margin="0,6,0,20" Foreground="#475569" TextWrapping="Wrap" />
            <TextBlock Text="Nome e cognome *" FontWeight="SemiBold" />
            <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Email *" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Password temporanea *" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBox Text="{Binding TemporaryPassword, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="Telefono" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBox Text="{Binding Phone}" />
            <TextBlock Text="Mansione" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBox Text="{Binding Job}" />
            <TextBlock Text="Reparto" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBox Text="{Binding Department}" />
            <TextBlock Text="Data assunzione" FontWeight="SemiBold" Margin="0,12,0,0" />
            <DatePicker SelectedDate="{Binding HireDate}" />
            <TextBlock Text="{Binding Message}" Margin="0,18,0,10" TextWrapping="Wrap" Foreground="#334155" />
            <Button Content="CREA DIPENDENTE E ACCESSO" Command="{Binding SaveCommand}"
                    Background="{StaticResource IronBlue}" Foreground="White"
                    FontWeight="Bold" Height="48" />
        </StackPanel>
    </ScrollViewer>
</Window>
