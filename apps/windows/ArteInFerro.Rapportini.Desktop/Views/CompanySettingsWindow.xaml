<Window x:Class="ArteInFerro.Rapportini.Desktop.Views.CompanySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Azienda e contatti · Arte In Ferro" Width="1250" Height="830" WindowStartupLocation="CenterOwner" Background="#F1F5F9">
    <TabControl Margin="18">
        <TabItem Header="DATI AZIENDA"><ScrollViewer><StackPanel Margin="24" MaxWidth="650" HorizontalAlignment="Left">
            <TextBlock Text="Anagrafica aziendale" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Ragione sociale *" FontWeight="SemiBold" Margin="0,14,0,0"/><TextBox Text="{Binding CompanyName}"/>
            <TextBlock Text="Partita IVA" FontWeight="SemiBold" Margin="0,9,0,0"/><TextBox Text="{Binding VatNumber}"/>
            <TextBlock Text="Codice fiscale" FontWeight="SemiBold" Margin="0,9,0,0"/><TextBox Text="{Binding FiscalCode}"/>
            <TextBlock Text="Indirizzo" FontWeight="SemiBold" Margin="0,9,0,0"/><TextBox Text="{Binding Address}"/>
            <WrapPanel><StackPanel Width="300"><TextBlock Text="Comune"/><TextBox Text="{Binding City}"/></StackPanel><StackPanel Width="130" Margin="10,0"><TextBlock Text="Provincia"/><TextBox Text="{Binding Province}"/></StackPanel><StackPanel Width="130"><TextBlock Text="CAP"/><TextBox Text="{Binding PostalCode}"/></StackPanel></WrapPanel>
            <TextBlock Text="Telefono" FontWeight="SemiBold" Margin="0,9,0,0"/><TextBox Text="{Binding Phone}"/>
            <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,9,0,0"/><TextBox Text="{Binding Email}"/>
            <TextBlock Text="PEC" FontWeight="SemiBold" Margin="0,9,0,0"/><TextBox Text="{Binding Pec}"/>
            <TextBlock Text="Sito web" FontWeight="SemiBold" Margin="0,9,0,0"/><TextBox Text="{Binding Website}"/>
            <TextBlock Text="{Binding Message}" Margin="0,14,0,8"/><Button Content="SALVA DATI AZIENDA" Command="{Binding SaveCompanyCommand}" Background="{StaticResource IronBlue}" Foreground="White" Height="44"/>
        </StackPanel></ScrollViewer></TabItem>
        <TabItem Header="CONTATTI, UFFICI ED EMERGENZE"><Grid Margin="14"><Grid.ColumnDefinitions><ColumnDefinition Width="380"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Background="White" Padding="20" CornerRadius="12"><StackPanel><TextBlock Text="Nuovo contatto" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Nome *" Margin="0,14,0,0"/><TextBox Text="{Binding ContactName}"/><TextBlock Text="Ruolo / reparto *" Margin="0,9,0,0"/><TextBox Text="{Binding ContactRole}"/>
                <TextBlock Text="Telefono" Margin="0,9,0,0"/><TextBox Text="{Binding ContactPhone}"/><TextBlock Text="Email" Margin="0,9,0,0"/><TextBox Text="{Binding ContactEmail}"/>
                <TextBlock Text="Tipo" Margin="0,9,0,0"/><ComboBox ItemsSource="{Binding ContactTypes}" SelectedItem="{Binding SelectedContactType}"/>
                <CheckBox Content="Visibile ai dipendenti nell’app" IsChecked="{Binding VisibleToEmployees}" Margin="0,14"/>
                <Button Content="AGGIUNGI CONTATTO" Command="{Binding AddContactCommand}" Background="{StaticResource IronBlue}" Foreground="White" Height="44"/></StackPanel></Border>
            <DataGrid Grid.Column="2" ItemsSource="{Binding Contacts}" AutoGenerateColumns="False" IsReadOnly="True" Background="White"><DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="Ruolo / reparto" Binding="{Binding DepartmentRole}" Width="220"/>
                <DataGridTextColumn Header="Telefono" Binding="{Binding Phone}" Width="150"/><DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/><DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="110"/>
            </DataGrid.Columns></DataGrid>
        </Grid></TabItem>
    </TabControl>
</Window>
